# Wuduh Environment Variables
# Copy this to .env.local and fill in your real values.
# NEVER commit .env.local to git.

# ── Database (PostgreSQL) ─────────────────────────────────────────────────
# Self-hosted on Coolify. Internal URL uses the container name as hostname.
DATABASE_URL=postgres://postgres:your-password@your-host:5432/wuduh

# ── Better Auth ───────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000

# ── App URL ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── MinIO (S3-compatible file storage) ───────────────────────────────────
# Self-hosted on Coolify.
MINIO_ENDPOINT=your-vps-ip
MINIO_PORT=9000
MINIO_ACCESS_KEY=your-minio-user
MINIO_SECRET_KEY=your-minio-password
MINIO_BUCKET=wuduh-uploads

# ── Resend (transactional email) ─────────────────────────────────────────
# Get your key at https://resend.com → API Keys
RESEND_API_KEY=re_your-key-here

# ── PDFShift (PDF generation) ────────────────────────────────────────────
# Get your key at https://pdfshift.io → Dashboard → API Keys
PDFSHIFT_API_KEY=sk_your-key-here
