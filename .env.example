# Wuduh Environment Variables
# Copy this to .env.local and fill in your real values.
# NEVER commit .env.local to git.

# Supabase — get these from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tqjflhqffbqdtqfxmzcf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL — used for email redirect links
NEXT_PUBLIC_APP_URL=http://localhost:3000
